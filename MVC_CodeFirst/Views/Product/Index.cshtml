@model IEnumerable<MVC_CodeFirst.Models.ViewModels.ProductViewModel>

@{
    ViewBag.Title = "Products";
}

<div class="container mt-4">
    <h2>Products</h2>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="close" data-dismiss="alert">&times;</button>
        </div>
    }

    <!-- Permission-based buttons area -->
    <div class="row mb-3">
        <div class="col-md-12">
            @{
                // Check if user has Create permission
                bool canCreate = ViewBag.CanAccess("Product", "Create");
                if (canCreate)
                {
                    @Html.ActionLink("Create New Product", "Create", null, new { @class = "btn btn-primary" })
                }
                else
                {
                    <button class="btn btn-primary" disabled title="You don't have permission for this">
                        Create New Product
                    </button>
                }
            }
        </div>
    </div>

    <!-- Search Form -->
    <div class="card mb-4">
        <div class="card-body">
            @using (Html.BeginForm("Index", "Product", FormMethod.Get, new { @class = "form-inline" }))
            {
                <div class="form-row w-100">
                    <div class="col-md-4 mb-2">
                        <label class="sr-only">Category</label>
                        @Html.DropDownList("categoryId",
                            ViewBag.Categories as SelectList,
                            "-- All Categories --",
                            new { @class = "form-control w-100" })
                    </div>

                    <div class="col-md-4 mb-2">
                        <label class="sr-only">Product Name</label>
                        @Html.TextBox("searchName",
                            ViewBag.SearchName as string,
                            new { @class = "form-control w-100", placeholder = "Search by product name..." })
                    </div>

                    <div class="col-md-4 mb-2">
                        <button type="submit" class="btn btn-primary mr-2">
                             Search
                        </button>
                        <a href="@Url.Action("Index", "Product")" class="btn btn-secondary">
                            Clear
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Products Grid -->
    @if (Model.Any())
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    @Html.Partial("_ProductCard", item)
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i> No products found matching your search criteria.
        </div>
    }
</div>

