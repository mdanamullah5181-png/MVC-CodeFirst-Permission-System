
@{
    ViewBag.Title = "ManageUserRoles";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row col-sm-12 col-lg-12 col-md-12">
    <h1>Role Manager</h1>
    <hr />
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success col-sm-12">
        @TempData["Message"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger col-sm-12">
        <strong>Error:</strong> @TempData["Error"]
    </div>
}

<div class="row col-sm-12 col-lg-12 col-md-12">
    <div class="col-sm-6 col-lg-6 col-md-6">
        <div class="panel panel-primary">
            <div class="panel-heading">
                <h4>Role List</h4>
            </div>
            <div class="panel-body">
                <table class="table table-striped table-hover col-sm-6 col-lg-6 col-md-6 ">
                    @foreach (var role in ViewBag.Roles)
                    {
                        <tr>
                            <td class="col-sm-1 col-lg-5 col-md-5">
                                <strong>@role.Text </strong>
                            </td>
                            <td class="col-sm-1 col-lg-1 col-md-1">
                                @{
                                    bool isAdmin = User.IsInRole("Admin");
                                    
                                    var hasDeletePermission = isAdmin || (ViewBag.UserPermissions != null && 
                                        ((List<MVC_CodeFirst.Models.RolePermission>)ViewBag.UserPermissions)
                                        .Any(p => p.ControllerName == "Role" && p.ActionName == "Delete"));
                                    
                                    var hasEditPermission = isAdmin || (ViewBag.UserPermissions != null && 
                                        ((List<MVC_CodeFirst.Models.RolePermission>)ViewBag.UserPermissions)
                                        .Any(p => p.ControllerName == "Role" && p.ActionName == "Edit"));
                                    
                                    var hasManagePermissionPermission = isAdmin || (ViewBag.UserPermissions != null && 
                                        ((List<MVC_CodeFirst.Models.RolePermission>)ViewBag.UserPermissions)
                                        .Any(p => p.ControllerName == "Role" && p.ActionName == "ManagePermission"));
                                }

                                @if (hasDeletePermission)
                                {
                                    using (Html.BeginForm("Delete", "Role", new { RoleName = role.Text }, FormMethod.Post, new { style = "display:inline;" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-link btn-xs" style="color:red; padding:0; text-decoration:underline;" onclick="return confirm('Are you sure to delete this role?');"><strong>Delete</strong></button>
                                    } <span>|</span>
                                }
                                
                                @if (hasEditPermission)
                                {
                                    @Html.ActionLink("Edit", "Edit", new { roleName = @role.Text }) <span>|</span>
                                }

                                @if (hasManagePermissionPermission)
                                {
                                    <a href="/Role/ManagePermission?roleId=@role.Value" style="color:blue; font-weight:bold;">Permission</a>
                                }
                            </td>
                        </tr>
                    }
                </table>
            </div>
        </div>

        <div class="panel panel-primary">
            <div class="panel-heading">
                <h4>Create A New Role</h4>
            </div>
            <div class="panel-body">
                @using (Html.BeginForm("Create", "Role", FormMethod.Post, new { @class = "form-inline" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label>Role name:</label>
                        @Html.TextBox("RoleName", null, new { @class = "form-control" })
                    </div>
                    <input type="submit" value="Save" class="btn btn-primary" />
                }
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-6 col-md-6">
        <div class="panel panel-primary">
            <div class="panel-heading">
                <h4>Add a Role to a User</h4>
            </div>
            <div class="panel-body">
                @using (Html.BeginForm("RoleAddToUser", "Role"))
                {
                    @Html.AntiForgeryToken()
                    <p>User Name: @Html.DropDownList("UserName", (IEnumerable<SelectListItem>)ViewBag.Users, "Select User...", new { @class = "form-control" })</p>
                    <p>Role Name: @Html.DropDownList("RoleName", (IEnumerable<SelectListItem>)ViewBag.Roles, "Select Role...", new { @class = "form-control" })</p>
                    <input type="submit" value="Assign Role" class="btn btn-primary" />
                }
            </div>
        </div>

        <div class="panel panel-primary">
            <div class="panel-heading">
                <h4>List Roles for a User</h4>
            </div>
            <div class="panel-body">
                @using (Html.BeginForm("GetRoles", "Role"))
                {
                    @Html.AntiForgeryToken()
                    <div class="input-group">
                        @Html.DropDownList("UserName", (IEnumerable<SelectListItem>)ViewBag.Users, "Select User...", new { @class = "form-control", @id = "listRolesUserDropdown" })
                        <span class="input-group-btn">
                            <input type="submit" value="Get Roles" class="btn btn-primary" />
                        </span>
                    </div>
                }

                @if (ViewBag.RolesForThisUser != null && ViewBag.RolesForThisUser.Count > 0)
                {
                    <div class="alert alert-info" style="margin-top:15px;">
                        <strong>Roles for @ViewBag.SelectedUserForDisplay:</strong>
                        <ul>
                            @foreach (string s in ViewBag.RolesForThisUser)
                            {
                                <li>@s</li>
                            }
                        </ul>
                    </div>
                }
                else if (ViewBag.SelectedUserForDisplay != null)
                {
                    <div class="alert alert-warning" style="margin-top:15px;">
                        <strong>@ViewBag.SelectedUserForDisplay</strong> has no roles assigned.
                    </div>
                }
            </div>
        </div>

        <div class="panel panel-primary">
            <div class="panel-heading">
                <h4>Remove Role from User</h4>
            </div>
            <div class="panel-body">
                @using (Html.BeginForm("DeleteRoleForUser", "Role"))
                {
                    @Html.AntiForgeryToken()
                    <p>User Name: @Html.DropDownList("UserName", (IEnumerable<SelectListItem>)ViewBag.Users, "Select User...", new { @class = "form-control", @id = "removeRoleUserDropdown", onchange = "loadUserRoles(this.value)" })</p>
                    <p>Role Name: @Html.DropDownList("RoleName", (IEnumerable<SelectListItem>)(ViewBag.UserRoles ?? new List<SelectListItem>()), "Select Role...", new { @class = "form-control", @id = "removeRoleDropdown" })</p>
                    <input type="submit" value="Remove Role" class="btn btn-danger" />
                }
            </div>
        </div>
    </div>
</div>

@if (ViewBag.Message != "")
{
    <div class="alert alert-success col-sm-12">
        @ViewBag.Message
    </div>
}

<script type="text/javascript">
    $(document).ready(function () {
        // Auto-populate selected user and roles if coming from "Get Roles"
        var selectedUserName = '@ViewBag.SelectedUserName' || '';
        if (selectedUserName) {
            $("#removeRoleUserDropdown").val(selectedUserName);
            loadUserRoles(selectedUserName);
        }
    });

    function loadUserRoles(userName) {
        if (!userName || userName === '') {
            // Clear the role dropdown
            $('#removeRoleDropdown').html('<option value="">Select Role...</option>');
            return;
        }

        // Send AJAX request to get roles for this user
        $.ajax({
            url: '@Url.Action("GetUserRolesAjax", "Role")',
            type: 'POST',
            data: { userName: userName },
            headers: {
                '__RequestVerificationToken': $('[name="__RequestVerificationToken"]').val()
            },
            success: function (data) {
                var dropdown = $('#removeRoleDropdown');
                dropdown.html('');

                if (data && data.length > 0) {
                    dropdown.append('<option value="">Select Role...</option>');
                    $.each(data, function (index, role) {
                        dropdown.append('<option value="' + role + '">' + role + '</option>');
                    });
                } else {
                    dropdown.append('<option value="">No roles assigned</option>');
                }
            },
            error: function () {
                $('#removeRoleDropdown').html('<option value="">Error loading roles</option>');
            }
        });
    }
</script>
