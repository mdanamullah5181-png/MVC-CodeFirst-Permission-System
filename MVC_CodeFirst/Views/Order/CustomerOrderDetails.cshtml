@model MVC_CodeFirst.Models.ViewModels.CustomerOrderSummaryViewModel

@{
    ViewBag.Title = "Customer Order Summary";
}

<div class="container mt-4">
    <h2>
        <i class="fas fa-user-tie"></i>
        Order Summary: @ViewBag.CustomerDisplayName
    </h2>
    <hr />

    <!-- Customer Card -->
    <div class="card mb-4">
        <div class="card-header bg-info text-white">
            <i class="fas fa-user-circle"></i> Customer Information
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <p><strong>Customer ID:</strong> #@Model.CustomerId</p>
                    <p><strong>Name:</strong> @Model.CustomerName</p>
                </div>
                <div class="col-md-4">
                    <p><strong>Phone:</strong> @Model.ContactNumber</p>
                    <p><strong>Address:</strong> @Model.ContactAddress</p>
                </div>
                <div class="col-md-4">
                    <p><strong>Total Orders:</strong> <span class="badge badge-primary">@Model.TotalOrders</span></p>
                    <p><strong>Total Spent:</strong> <span class="badge badge-success">@Model.TotalSpent.ToString("N2")</span></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Orders -->
    @if (Model.Orders != null && Model.Orders.Any())
    {
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <i class="fas fa-shopping-cart"></i> Orders (@Model.Orders.Count)
            </div>
            <div class="card-body">
                <table class="table table-bordered">
                    <thead class="thead-dark">
                        <tr>
                            <th>Order ID</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            <tr>
                                <td>#@order.OrderId</td>
                                <td>@order.OrderDate.ToString("dd-MMM-yyyy")</td>
                                <td>@order.NumberOfItems items</td>
                                <td class="font-weight-bold">@order.TotalAmount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Back Button -->
    <div class="mt-3">
        @Html.ActionLink("Select Another Customer", "CustomerSummary", null,
            new { @class = "btn btn-secondary" })
        @Html.ActionLink("Back to Orders", "Index", null,
            new { @class = "btn btn-outline-secondary ml-2" })
    </div>
</div>