@{
    ViewBag.Title = "Home Page";
}

<style>
    .landing-page-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        padding: 30px 20px;
    }

    .shop-name {
        text-align: center;
        color: #eaeaea;
    }

    .shop-name h1 {
        font-size: 4rem;
        color: #e63946;
        font-weight: 700;
        margin-bottom: 20px;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    }

    .shop-name h2 {
        font-size: 2rem;
        color: #b0b0b0;
        font-weight: 400;
    }

    @@media (max-width: 768px) {
        .shop-name h1 {
            font-size: 2.5rem;
        }
        
        .shop-name h2 {
            font-size: 1.5rem;
        }
    }
</style>

<div class="landing-page-container">
    <div class="shop-name">
        <h1>Mobile Shop</h1>
        <h2>Management System</h2>
    </div>
</div>